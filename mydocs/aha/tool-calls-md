Recommendation for amplifier-core

The fix should be in amplifier-core or foundation behaviors, not the provider:


 # In orchestrator or tool executor:
 def validate_tool_call(tool_call: ToolCall) -> ToolResult | None:
     """Reject malformed tool calls BEFORE execution."""
     tool_schema = get_tool_schema(tool_call.name)
     missing_params = [p for p in tool_schema.required if p not in tool_call.arguments]

     if missing_params:
         # Return error WITHOUT executing — don't waste API calls
         return ToolResult(
             error=f"Missing required parameters: {missing_params}. "
                   f"Tool {tool_call.name} requires: {tool_schema.required}"
         )
     return None  # Valid, proceed with execution


